# =============================================================================
# Python / Poetry
# =============================================================================
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
.eggs/

# =============================================================================
# dbt
# =============================================================================
target/           # 컴파일된 SQL, 실행 결과물
dbt_packages/     # dbt deps로 설치되는 외부 패키지
logs/             # dbt 실행 로그

# =============================================================================
# Spark / Docker
# =============================================================================
derby.log         # Spark 로컬 모드 Derby DB 로그
metastore_db/     # Hive metastore 로컬 DB

# =============================================================================
# bkit (PDCA 도구)
# =============================================================================
.bkit/runtime/    # 세션 런타임 상태 (임시)
.bkit/audit/      # 감사 로그 (로컬 전용)

# .bkit/state/    → 커밋 대상 (PDCA 진행 상태 공유)
# .bkit/workflows/ → 커밋 대상 (워크플로 설정 공유)

# =============================================================================
# OS / IDE
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
